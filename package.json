{
  "name": "create-x-app-cli",
  "version": "1.0.4",
  "description": "交互式 Node.js CLI，用于生成生产级多场景项目模板",
  "keywords": [
    "cli",
    "cli-tool",
    "scaffold",
    "scaffolding",
    "starter",
    "starter-kit",
    "template",
    "templates",
    "generator",
    "project-generator",
    "create-app",
    "nodejs",
    "react",
    "vite",
    "typescript",
    "spring-boot",
    "electron",
    "chrome-extension",
    "monorepo",
    "plugin"
  ],
  "author": "赵铁柱",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yexianglun-d/create-x-app.git"
  },
  "homepage": "https://github.com/yexianglun-d/create-x-app#readme",
  "bugs": {
    "url": "https://github.com/yexianglun-d/create-x-app/issues"
  },
  "type": "module",
  "bin": {
    "create-x-app": "bin/cli.js",
    "create-x-app-cli": "bin/cli.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "bin",
    "src",
    "schemas",
    "templates",
    "shared",
    "examples/cxa-plugin-example",
    "docs/*.md",
    "docs/usage-impact-proof.html",
    "CHANGELOG.md",
    "CODE_OF_CONDUCT.md",
    "CONTRIBUTING.md",
    "RELEASE_COMMANDS.md",
    "SECURITY.md",
    "SUPPORT.md"
  ],
  "scripts": {
    "dev": "node bin/cli.js",
    "lint": "eslint src test",
    "test": "npm run test:unit",
    "test:unit": "node --test test/unit/*.test.js",
    "test:integration": "node test/integration/runner.js",
    "test:snapshot-update": "node test/integration/runner.js --update-snapshots",
    "test:smoke": "node test/smoke/runner.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "ejs": "^3.1.10",
    "execa": "^9.3.0",
    "fs-extra": "^11.2.0",
    "semver": "^7.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0"
  }
}
