{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://create-x-app.dev/schemas/manifest-v1.json",
  "title": "create-x-app template manifest v1",
  "type": "object",
  "required": [
    "schemaVersion",
    "key",
    "name",
    "description",
    "version",
    "framework",
    "requiredPm",
    "forbiddenPm",
    "requiredEnv",
    "optionalEnv",
    "features",
    "supportedFeatures",
    "defaultFeatures",
    "extras",
    "subPrompts",
    "devScript",
    "buildScript",
    "devPort"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.0"
    },
    "key": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "framework": {
      "type": "string",
      "minLength": 1
    },
    "requirements": {
      "type": "object",
      "description": "模板级环境需求。工具字段使用 semver 最低要求，packageManagers 声明可选包管理器。",
      "properties": {
        "node": {
          "type": ["string", "null"]
        },
        "git": {
          "type": ["string", "null"]
        },
        "pnpm": {
          "type": ["string", "null"]
        },
        "yarn": {
          "type": ["string", "null"]
        },
        "java": {
          "type": ["string", "null"]
        },
        "docker": {
          "type": ["string", "null"]
        },
        "packageManagers": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["npm", "pnpm", "yarn"]
          },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "cxaPluginApi": {
      "type": "string",
      "minLength": 1,
      "description": "插件兼容的 create-x-app Plugin API semver range，例如 >=1.0.0 <2.0.0"
    },
    "author": {
      "type": "string"
    },
    "repository": {
      "type": "string"
    },
    "license": {
      "type": "string"
    },
    "requiresNetwork": {
      "type": "boolean",
      "default": false
    },
    "postActions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "writesOutsideTarget": {
      "type": "boolean",
      "default": false
    },
    "requiredPm": {
      "type": ["string", "null"],
      "enum": ["npm", "pnpm", "yarn", null]
    },
    "forbiddenPm": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["npm", "pnpm", "yarn"]
      },
      "uniqueItems": true
    },
    "requiredEnv": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "optionalEnv": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "features": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["label", "default"],
        "properties": {
          "label": {
            "type": "string",
            "minLength": 1
          },
          "hint": {
            "type": "string"
          },
          "default": {
            "type": "boolean"
          },
          "artifacts": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "postActions": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "additionalProperties": true
      }
    },
    "supportedFeatures": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "defaultFeatures": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "extras": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["key", "label", "default", "source"],
        "properties": {
          "key": {
            "type": "string",
            "minLength": 1
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "default": {
            "type": "boolean"
          },
          "source": {
            "type": "string",
            "enum": ["inline", "file"]
          },
          "templatePath": {
            "type": "string"
          },
          "artifacts": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "detectDependencies": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "additionalProperties": true
      }
    },
    "subPrompts": {
      "type": "array"
    },
    "subPromptArtifacts": {
      "type": "array"
    },
    "devScript": {
      "type": ["string", "null"]
    },
    "buildScript": {
      "type": ["string", "null"]
    },
    "devPort": {
      "type": ["integer", "null"]
    },
    "integrationTest": {
      "type": "object"
    },
    "upgrade": {
      "type": "object",
      "properties": {
        "managedFiles": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
