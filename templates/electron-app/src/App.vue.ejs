<script setup lang="ts">
import { computed, onMounted, ref } from 'vue'
import { useElectron, type SystemInfo } from './composables/useElectron'

const { getSystemInfo } = useElectron()
const systemInfo = ref<SystemInfo | null>(null)
const errorMessage = ref('')

const detailItems = computed(() => {
  if (!systemInfo.value) {
    return []
  }

  return [
    { label: '平台', value: systemInfo.value.platform },
    { label: '架构', value: systemInfo.value.arch },
    { label: '主机名', value: systemInfo.value.hostname },
    { label: '系统版本', value: systemInfo.value.release },
    { label: 'Node', value: systemInfo.value.nodeVersion },
    { label: 'Electron', value: systemInfo.value.electronVersion },
    { label: 'Chrome', value: systemInfo.value.chromeVersion },
  ]
})

onMounted(async () => {
  try {
    systemInfo.value = await getSystemInfo()
  } catch (error) {
    errorMessage.value = error instanceof Error ? error.message : '读取系统信息失败'
  }
})
</script>

<template>
  <main class="shell">
    <section class="hero">
      <span class="kicker">create-x-app / electron-app</span>
      <h1 class="title"><%= projectName %></h1>
      <p class="desc">
        这是一个 Electron + Vue 3 桌面模板，已接好主进程、preload 和 IPC 示例，
        你可以直接在此基础上扩展菜单、窗口、系统能力与业务模块。
      </p>
    </section>

    <section class="panel">
      <div class="panel-head">
        <h2>系统信息</h2>
        <span class="badge">IPC Ready</span>
      </div>

      <p v-if="errorMessage" class="error">{{ errorMessage }}</p>

      <div v-else-if="systemInfo" class="grid">
        <article v-for="item in detailItems" :key="item.label" class="card">
          <p class="card-label">{{ item.label }}</p>
          <p class="card-value">{{ item.value }}</p>
        </article>
      </div>

      <p v-else class="loading">正在通过 preload 调用主进程获取系统信息...</p>
    </section>
  </main>
</template>

