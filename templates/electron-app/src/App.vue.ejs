<script setup lang="ts">
import { onMounted, ref } from 'vue'
import { useElectron, type BatchItem } from './composables/useElectron'

const statusLabels: Record<BatchItem['status'], string> = {
  queued: '待处理',
  processing: '处理中',
  done: '已完成',
}

const statusOptions: BatchItem['status'][] = ['queued', 'processing', 'done']
const { readBatchItems, saveBatchItems, selectFiles } = useElectron()
const items = ref<BatchItem[]>([])
const message = ref('正在读取本地工作区...')

onMounted(async () => {
  try {
    items.value = await readBatchItems()
    message.value = items.value.length > 0 ? '已载入上次保存的处理清单。' : '请选择需要处理的文件。'
  } catch (error) {
    message.value = error instanceof Error ? error.message : '读取工作区失败'
  }
})

async function handleSelectFiles() {
  const selectedItems = await selectFiles()

  if (selectedItems.length === 0) {
    message.value = '没有选择文件。'
    return
  }

  items.value = [...selectedItems, ...items.value]
  message.value = `已加入 ${selectedItems.length} 个文件。`
}

function updateStatus(itemId: string, status: BatchItem['status']) {
  items.value = items.value.map((item) => item.id === itemId
    ? { ...item, status, note: statusLabels[status] }
    : item)
}

function handleStatusChange(itemId: string, event: Event) {
  const target = event.target

  if (!(target instanceof HTMLSelectElement)) {
    return
  }

  updateStatus(itemId, target.value as BatchItem['status'])
}

async function handleSave() {
  items.value = await saveBatchItems(items.value)
  message.value = `已保存 ${items.value.length} 个处理项。`
}
</script>

<template>
  <main class="shell">
    <section class="hero">
      <p class="workspace-name"><%= projectName %></p>
      <h1>本地批处理工作台</h1>
      <p>选择本机文件，维护处理状态，并把工作清单保存到桌面应用本地目录。</p>
    </section>

    <section class="panel">
      <div class="panel-head">
        <div>
          <h2>处理清单</h2>
          <p>{{ message }}</p>
        </div>
        <div class="actions">
          <button class="secondary-button" type="button" @click="handleSave">保存</button>
          <button class="primary-button" type="button" @click="handleSelectFiles">选择文件</button>
        </div>
      </div>

      <p v-if="items.length === 0" class="empty">暂无文件。选择合同、表格或图片后即可开始维护处理状态。</p>

      <div v-else class="item-list">
        <article v-for="item in items" :key="item.id" class="item-row">
          <div class="item-main">
            <h3>{{ item.fileName }}</h3>
            <p>{{ item.filePath }}</p>
          </div>
          <select
            :value="item.status"
            @change="handleStatusChange(item.id, $event)"
          >
            <option v-for="status in statusOptions" :key="status" :value="status">
              {{ statusLabels[status] }}
            </option>
          </select>
        </article>
      </div>
    </section>
  </main>
</template>

