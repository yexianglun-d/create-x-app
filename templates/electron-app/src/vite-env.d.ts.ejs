interface ElectronSystemInfo {
  platform: string
  arch: string
  hostname: string
  release: string
  nodeVersion: string
  electronVersion: string
  chromeVersion: string
}

interface ElectronAPI {
  getSystemInfo: () => Promise<ElectronSystemInfo>
}

interface Window {
  electronAPI?: ElectronAPI
}

