/// <reference types="vite/client" />

interface ElectronBatchItem {
  id: string
  fileName: string
  filePath: string
  status: 'queued' | 'processing' | 'done'
  note: string
}

interface ElectronAPI {
  selectFiles: () => Promise<ElectronBatchItem[]>
  readBatchItems: () => Promise<ElectronBatchItem[]>
  saveBatchItems: (items: ElectronBatchItem[]) => Promise<ElectronBatchItem[]>
}

interface Window {
  electronAPI?: ElectronAPI
}

<% if (renderer === 'vue') { %>declare module '*.vue' {
  import type { DefineComponent } from 'vue'

  const component: DefineComponent<Record<string, never>, Record<string, never>, unknown>
  export default component
}
<% } %>
