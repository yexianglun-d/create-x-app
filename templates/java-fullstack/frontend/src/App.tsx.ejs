import { FormEvent, useEffect, useState } from 'react'
import './App.css'

type Priority = 'HIGH' | 'MEDIUM' | 'LOW'
type TaskStage = 'TODO' | 'IN_PROGRESS' | 'REVIEW' | 'DONE'

interface TaskItem {
  id: string
  title: string
  assignee: string
  stage: TaskStage
  priority: Priority
  nextStep: string
  dueAt: string
}

interface ApiResponse<T> {
  code: number
  data: T
  message: string
}

const stageLabels: Record<TaskStage, string> = {
  TODO: '待办',
  IN_PROGRESS: '进行中',
  REVIEW: '评审中',
  DONE: '已完成',
}

const priorityLabels: Record<Priority, string> = {
  HIGH: '高',
  MEDIUM: '中',
  LOW: '低',
}

export default function App() {
  const [tasks, setTasks] = useState<TaskItem[]>([])
  const [message, setMessage] = useState('正在连接后端服务...')
  const [title, setTitle] = useState('')
  const [nextStep, setNextStep] = useState('')

  async function loadTasks() {
    try {
      const response = await fetch('/api/tasks')
      const payload = await response.json() as ApiResponse<TaskItem[]>

      setTasks(payload.data)
      setMessage('数据已同步')
    } catch {
      setMessage('后端服务未启动，运行 backend 目录下的 mvn spring-boot:run 后会自动联调。')
    }
  }

  async function handleCreateTask(event: FormEvent<HTMLFormElement>) {
    event.preventDefault()

    if (!title.trim() || !nextStep.trim()) {
      setMessage('请填写任务名称和下一步动作。')
      return
    }

    const response = await fetch('/api/tasks', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
      },
      body: JSON.stringify({
        title,
        nextStep,
        priority: 'medium',
      }),
    })
    const payload = await response.json() as ApiResponse<TaskItem>

    setTasks((currentTasks) => [payload.data, ...currentTasks])
    setTitle('')
    setNextStep('')
    setMessage('已创建任务。')
  }

  useEffect(() => {
    void loadTasks()
  }, [])

  return (
    <main className="app-shell">
      <section className="workspace-header">
        <div>
          <p className="workspace-name"><%= projectName %></p>
          <h1>全栈任务工作台</h1>
          <p>React 前端与 Spring Boot 后端共用任务管理流程，适合作为 Java 全栈项目的第一版业务骨架。</p>
        </div>
        <form className="action-form" onSubmit={handleCreateTask}>
          <label htmlFor="title">任务名称</label>
          <input
            id="title"
            value={title}
            onChange={(event) => setTitle(event.target.value)}
            placeholder="例如：完成项目方案"
          />
          <label htmlFor="nextStep">下一步动作</label>
          <input
            id="nextStep"
            value={nextStep}
            onChange={(event) => setNextStep(event.target.value)}
            placeholder="例如：确认需求文档"
          />
          <button type="submit">创建任务</button>
        </form>
      </section>

      <section className="summary-grid">
        <article>
          <span>任务总数</span>
          <strong>{tasks.length}</strong>
        </article>
        <article>
          <span>高优先级</span>
          <strong>{tasks.filter((task) => task.priority === 'HIGH').length}</strong>
        </article>
        <article>
          <span>接口状态</span>
          <strong>{message === '数据已同步' ? '正常' : '待连接'}</strong>
        </article>
      </section>

      <section className="panel">
        <div className="panel-head">
          <h2>任务列表</h2>
          <span>{message}</span>
        </div>
        {tasks.length === 0 ? (
          <p className="empty-state">暂无任务。后端启动后会加载初始数据，也可以通过右上表单创建。</p>
        ) : (
          <div className="action-list">
            {tasks.map((task) => (
              <article className="action-row" key={task.id}>
                <div>
                  <h3>{task.title}</h3>
                  <p>{task.nextStep}</p>
                </div>
                <div className="action-meta">
                  <span className="stage">{stageLabels[task.stage]}</span>
                  <span>{task.assignee}</span>
                  <span>{priorityLabels[task.priority]}优先级</span>
                  <span>{task.dueAt}</span>
                </div>
              </article>
            ))}
          </div>
        )}
      </section>
    </main>
  )
}
