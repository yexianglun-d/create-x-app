{
  "key": "java-fullstack",
  "name": "Java 全栈 + 前端配套说明",
  "description": "前端工程与 Spring Boot 后端搭建说明一并生成",
  "version": "1.0.0",
  "schemaVersion": "1.0",
  "framework": "react",
  "requirements": {
    "node": ">=18.0.0",
    "packageManagers": [
      "npm",
      "pnpm",
      "yarn"
    ]
  },
  "requiredPm": null,
  "forbiddenPm": [],
  "requiredEnv": {
    "node": ">=18.0.0"
  },
  "optionalEnv": {
    "java": ">=21.0.0"
  },
  "supportedFeatures": [
    "eslint",
    "prettier",
    "husky",
    "agents",
    "coding-rules",
    "ai-native"
  ],
  "defaultFeatures": [
    "eslint",
    "prettier",
    "husky",
    "agents",
    "coding-rules"
  ],
  "features": {
    "eslint": {
      "label": "ESLint",
      "hint": "代码质量检查",
      "default": true,
      "artifacts": [
        "frontend/eslint.config.js"
      ]
    },
    "prettier": {
      "label": "Prettier",
      "hint": "代码格式化",
      "default": true,
      "artifacts": [
        "frontend/.prettierrc"
      ]
    },
    "husky": {
      "label": "commitlint + Husky",
      "hint": "提交信息校验",
      "default": true,
      "artifacts": [
        ".husky",
        "commitlint.config.js"
      ],
      "postActions": [
        "husky.install",
        "husky.chmod"
      ]
    },
    "agents": {
      "label": "AGENTS.md",
      "hint": "AI 协作约定",
      "default": true,
      "artifacts": [
        "AGENTS.md"
      ]
    },
    "coding-rules": {
      "label": "coding-rules.md",
      "hint": "团队代码规范",
      "default": true,
      "artifacts": [
        "coding-rules.md"
      ]
    },
    "ai-native": {
      "label": "AI-native 工程规范",
      "hint": "Cursor / Claude / Copilot / MCP / ADR / Prompt 文件",
      "default": false,
      "artifacts": [
        ".cursor/rules/create-x-app.mdc",
        "CLAUDE.md",
        ".github/copilot-instructions.md",
        ".mcp.example.json",
        "docs/adr/0001-project-conventions.md",
        "docs/prompts/pr-review.md",
        "docs/prompts/commit-message.md"
      ]
    }
  },
  "extras": [],
  "subPrompts": [],
  "devScript": "dev",
  "buildScript": "build",
  "devPort": 5173,
  "upgrade": {
    "managedFiles": [
      "docker-compose.yml",
      "frontend/tsconfig.json",
      "frontend/tsconfig.node.json",
      "frontend/eslint.config.js",
      "frontend/vite.config.ts",
      "frontend/.prettierrc",
      "commitlint.config.js"
    ]
  },
  "integrationTest": {
    "skipBuild": false,
    "skipDevServer": false,
    "installWorkspaces": [
      ".",
      "frontend"
    ],
    "buildWorkspace": "frontend"
  }
}
