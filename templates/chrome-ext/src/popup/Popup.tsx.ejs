import { useEffect, useState } from 'react'
import type { CSSProperties } from 'react'

interface PageNote {
  id: string
  title: string
  url: string
  selection: string
  capturedAt: string
}

const STORAGE_KEY = 'page-notes'

function queryActiveTabId() {
  return new Promise<number>((resolve, reject) => {
    chrome.tabs.query({ active: true, currentWindow: true }, (tabs) => {
      const errorMessage = chrome.runtime.lastError?.message

      if (errorMessage) {
        reject(new Error(errorMessage))
        return
      }

      const activeTabId = tabs[0]?.id

      if (typeof activeTabId !== 'number') {
        reject(new Error('未找到当前活动标签页'))
        return
      }

      resolve(activeTabId)
    })
  })
}

function captureActivePage(tabId: number) {
  return new Promise<Omit<PageNote, 'id'>>((resolve, reject) => {
    chrome.tabs.sendMessage(tabId, { type: 'capture-page-context' }, (response) => {
      const errorMessage = chrome.runtime.lastError?.message

      if (errorMessage) {
        reject(new Error(errorMessage))
        return
      }

      resolve(response as Omit<PageNote, 'id'>)
    })
  })
}

function readSavedNotes() {
  return new Promise<PageNote[]>((resolve) => {
    chrome.storage.local.get(STORAGE_KEY, (result) => {
      const notes = result[STORAGE_KEY]

      resolve(Array.isArray(notes) ? notes as PageNote[] : [])
    })
  })
}

function saveNotes(notes: PageNote[]) {
  return new Promise<void>((resolve) => {
    chrome.storage.local.set({ [STORAGE_KEY]: notes }, () => resolve())
  })
}

export default function Popup() {
  const [notes, setNotes] = useState<PageNote[]>([])
  const [feedback, setFeedback] = useState('打开网页后可采集标题、链接和选中文本。')
  const [isSubmitting, setIsSubmitting] = useState(false)

  useEffect(() => {
    void readSavedNotes().then((savedNotes) => setNotes(savedNotes.slice(0, 5)))
  }, [])

  async function handleCapturePage() {
    setIsSubmitting(true)

    try {
      const activeTabId = await queryActiveTabId()
      const pageContext = await captureActivePage(activeTabId)
      const nextNote: PageNote = {
        id: `${Date.now()}`,
        ...pageContext,
      }
      const nextNotes = [nextNote, ...notes].slice(0, 10)

      await saveNotes(nextNotes)
      setNotes(nextNotes)
      setFeedback('已保存到本地采集清单。')
    } catch (error) {
      setFeedback(error instanceof Error ? error.message : '采集失败')
    } finally {
      setIsSubmitting(false)
    }
  }

  return (
    <main style={shellStyle}>
      <section style={headerStyle}>
        <p style={workspaceNameStyle}><%= projectName %></p>
        <h1 style={titleStyle}>网页采集清单</h1>
        <p style={descriptionStyle}>保存当前网页的标题、链接和选中文本，后续可同步到笔记应用、任务管理器或知识库。</p>
      </section>

      <button
        type="button"
        disabled={isSubmitting}
        onClick={() => {
          void handleCapturePage()
        }}
        style={{
          ...primaryButtonStyle,
          opacity: isSubmitting ? 0.72 : 1,
          cursor: isSubmitting ? 'progress' : 'pointer',
        }}
      >
        {isSubmitting ? '采集中...' : '采集当前网页'}
      </button>

      <p style={feedbackStyle}>{feedback}</p>

      <section style={listStyle}>
        <div style={listHeadStyle}>
          <h2 style={listTitleStyle}>最近采集</h2>
          <span style={countStyle}>{notes.length} 条</span>
        </div>

        {notes.length === 0 ? (
          <p style={emptyStyle}>暂无记录。选中页面关键文字后点击采集，会一并保存选中文本。</p>
        ) : (
          notes.slice(0, 5).map((note) => (
            <article key={note.id} style={noteStyle}>
              <strong style={noteTitleStyle}>{note.title}</strong>
              <span style={noteUrlStyle}>{note.url}</span>
              {note.selection ? <p style={selectionStyle}>{note.selection}</p> : null}
            </article>
          ))
        )}
      </section>
    </main>
  )
}

