{
  "manifest_version": 3,
  "name": "<%= projectName %>",
  "version": "1.0.0",
  "description": "采集当前网页标题、链接和选中文本，沉淀为本地笔记。",
  "permissions": ["storage", "activeTab"],
  "action": {
    "default_popup": "popup/index.html"
  },
  "background": {
    "service_worker": "background/index.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/index.js"]
    }
  ]
}
