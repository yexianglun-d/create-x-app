<% if (extras.includes('react-router')) { %>import { BrowserRouter, NavLink, Route, Routes } from 'react-router-dom'
<% } %>import { FormEvent, useState } from 'react'

const initialTasks = [
  ['完成项目需求分析', '进行中', '撰写需求文档初稿', '今天 17:00'],
  ['设计系统架构方案', '待处理', '确认技术选型', '明天 10:30'],
  ['编写单元测试用例', '待排期', '覆盖核心业务逻辑', '周五'],
]

const actions = [
  ['高', '核对本周待办事项进度', '进行中'],
  ['中', '整理项目文档并归档', '待处理'],
  ['低', '复盘上月迭代交付情况', '已完成'],
]

function DashboardPage() {
  const [tasks, setTasks] = useState(initialTasks)
  const [taskName, setTaskName] = useState('')
  const [feedback, setFeedback] = useState('新增事项会即时出现在任务列表顶部。')

  function handleAddTask(event: FormEvent<HTMLFormElement>) {
    event.preventDefault()

    const normalizedName = taskName.trim()

    if (!normalizedName) {
      setFeedback('请先填写任务名称。')
      return
    }

    setTasks([[normalizedName, '新建', '安排首次处理', '待定'], ...tasks])
    setTaskName('')
    setFeedback('已加入今日任务清单。')
  }

  return (
    <main className="mx-auto w-full max-w-6xl px-5 py-8 text-slate-900">
      <section className="mb-6 grid gap-5 lg:grid-cols-[1fr_400px]">
        <div>
          <p className="mb-3 text-sm font-semibold text-slate-500"><%= projectName %></p>
          <h1 className="text-4xl font-bold leading-tight tracking-normal md:text-6xl">今日任务工作台</h1>
          <p className="mt-4 max-w-2xl text-base leading-7 text-slate-600">
            把待办任务、执行动作和下一步计划放在同一个轻量界面里，适合多数业务项目继续扩展。
          </p>
        </div>
        <form className="rounded-lg border border-slate-200 bg-white p-5 shadow-sm" onSubmit={handleAddTask}>
          <label className="mb-3 block font-semibold" htmlFor="taskName">新增任务</label>
          <div className="flex gap-2">
            <input
              id="taskName"
              className="min-w-0 flex-1 rounded-lg border border-slate-300 px-3 py-2"
              value={taskName}
              onChange={(event) => setTaskName(event.target.value)}
              placeholder="例如：完成技术方案"
            />
            <button className="rounded-lg bg-blue-700 px-4 font-semibold text-white" type="submit">加入</button>
          </div>
          <p className="mt-3 text-sm text-slate-500">{feedback}</p>
        </form>
      </section>

      <section className="mb-5 grid gap-3 md:grid-cols-3">
        {[
          ['待办任务', tasks.length, '持续更新任务状态'],
          ['高优先级', 1, '建议今天收口'],
          ['已完成', 1, '保持交付节奏'],
        ].map(([label, value, desc]) => (
          <article key={label} className="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
            <span className="text-sm text-slate-500">{label}</span>
            <strong className="my-2 block text-3xl">{value}</strong>
            <small className="text-slate-500">{desc}</small>
          </article>
        ))}
      </section>

      <section className="grid gap-5 lg:grid-cols-[1.7fr_0.8fr]">
        <div className="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
          <div className="mb-4 flex items-center justify-between">
            <h2 className="m-0 text-xl font-bold">任务列表</h2>
            <span className="text-sm text-slate-500">{tasks.length} 条</span>
          </div>
          <div className="grid gap-3">
            {tasks.map(([title, stage, nextStep, dueAt]) => (
              <article key={`${title}-${dueAt}`} className="rounded-lg border border-slate-100 bg-slate-50 p-4">
                <div className="flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
                  <div>
                    <strong className="text-base text-slate-900">{title}</strong>
                    <p className="mt-1 text-sm text-slate-500">下一步：{nextStep}</p>
                  </div>
                  <div className="flex flex-wrap items-center gap-2 text-sm text-slate-500">
                    <span className="rounded bg-blue-100 px-2 py-0.5 text-blue-700">{stage}</span>
                    <span>{dueAt}</span>
                  </div>
                </div>
              </article>
            ))}
          </div>
        </div>

        <div className="grid content-start gap-3">
          <div className="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
            <h2 className="mb-4 text-xl font-bold">执行动作</h2>
            <div className="grid gap-3">
              {actions.map(([priority, title, status]) => (
                <article key={title} className="rounded-lg border border-slate-100 bg-slate-50 p-4">
                  <div className="flex items-center justify-between">
                    <div>
                      <span className={`mr-2 inline-block rounded px-1.5 py-0.5 text-xs font-semibold ${
                        priority === '高' ? 'bg-red-100 text-red-700' : priority === '中' ? 'bg-amber-100 text-amber-700' : 'bg-emerald-100 text-emerald-700'
                      }`}>{priority}</span>
                      <strong className="text-sm text-slate-900">{title}</strong>
                    </div>
                    <span className="text-xs text-slate-500">{status}</span>
                  </div>
                </article>
              ))}
            </div>
          </div>

          <div className="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
            <h2 className="mb-3 text-xl font-bold">常用操作</h2>
            <div className="grid gap-2">
              {[
                ['导出任务清单', '将当前列表导出为 CSV'],
                ['归档已完成项', '清理过期任务'],
                ['查看迭代报告', '了解本周交付情况'],
              ].map(([label, desc]) => (
                <button key={label} className="rounded-lg border border-slate-200 bg-white p-4 text-left shadow-sm transition hover:border-blue-300 hover:shadow-md">
                  <strong className="block text-sm text-slate-900">{label}</strong>
                  <small className="text-slate-500">{desc}</small>
                </button>
              ))}
            </div>
          </div>
        </div>
      </section>
    </main>
  )
}<% if (extras.includes('react-router')) { %>

function SettingsPage() {
  return (
    <main className="mx-auto w-full max-w-6xl px-5 py-8 text-slate-900">
      <h1 className="text-3xl font-bold">设置</h1>
      <p className="mt-3 max-w-2xl text-base text-slate-600">
        此页面占位用于演示 Tailwind CSS 与 react-router 的路由联动。你可以在 src/main.tsx 中把 app 渲染为 BrowserRouter，然后在这里扩展偏好设置、通知管理等功能。
      </p>
    </main>
  )
}

export default function App() {
  return (
    <BrowserRouter>
      <nav className="mx-auto flex max-w-6xl items-center gap-4 px-5 py-3 text-sm font-semibold text-slate-600">
        <NavLink className={({ isActive }) => isActive ? 'text-blue-700' : undefined} to="/">仪表盘</NavLink>
        <NavLink className={({ isActive }) => isActive ? 'text-blue-700' : undefined} to="/settings">设置</NavLink>
      </nav>
      <Routes>
        <Route element={<DashboardPage />} index />
        <Route element={<SettingsPage />} path="/settings" />
      </Routes>
    </BrowserRouter>
  )
}<% } else { %>
export default DashboardPage
<% } %>
