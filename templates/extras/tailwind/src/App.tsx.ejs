<% if (extras.includes('react-router')) { %>import { BrowserRouter, NavLink, Route, Routes } from 'react-router-dom'
<% } %>import { FormEvent, useState } from 'react'

const initialClients = [
  ['华东渠道续约', '合同确认', '补齐采购审批附件', '今天 17:00'],
  ['新门店上线支持', '方案沟通', '发送开店物料清单', '明天 10:30'],
  ['季度培训排期', '待排期', '确认一线主管名单', '周五'],
]

const tasks = [
  ['高', '核对本周高优客户跟进记录', '进行中'],
  ['中', '整理活动报名名单并分配负责人', '待处理'],
  ['低', '复盘上月工单响应时长', '已完成'],
]

function DashboardPage() {
  const [clients, setClients] = useState(initialClients)
  const [clientName, setClientName] = useState('')
  const [feedback, setFeedback] = useState('新增事项会即时出现在客户列表顶部。')

  function handleAddClient(event: FormEvent<HTMLFormElement>) {
    event.preventDefault()

    const normalizedName = clientName.trim()

    if (!normalizedName) {
      setFeedback('请先填写客户或事项名称。')
      return
    }

    setClients([[normalizedName, '新建', '安排首次跟进', '待定'], ...clients])
    setClientName('')
    setFeedback('已加入今日跟进清单。')
  }

  return (
    <main className="mx-auto w-full max-w-6xl px-5 py-8 text-slate-900">
      <section className="mb-6 grid gap-5 lg:grid-cols-[1fr_400px]">
        <div>
          <p className="mb-3 text-sm font-semibold text-slate-500"><%= projectName %></p>
          <h1 className="text-4xl font-bold leading-tight tracking-normal md:text-6xl">今日业务工作台</h1>
          <p className="mt-4 max-w-2xl text-base leading-7 text-slate-600">
            把客户跟进、待办事项和下一步动作放在同一个轻量界面里，适合多数业务项目继续扩展。
          </p>
        </div>
        <form className="rounded-lg border border-slate-200 bg-white p-5 shadow-sm" onSubmit={handleAddClient}>
          <label className="mb-3 block font-semibold" htmlFor="clientName">新增跟进事项</label>
          <div className="flex gap-2">
            <input
              id="clientName"
              className="min-w-0 flex-1 rounded-lg border border-slate-300 px-3 py-2"
              value={clientName}
              onChange={(event) => setClientName(event.target.value)}
              placeholder="例如：华南客户回访"
            />
            <button className="rounded-lg bg-blue-700 px-4 font-semibold text-white" type="submit">加入</button>
          </div>
          <p className="mt-3 text-sm text-slate-500">{feedback}</p>
        </form>
      </section>

      <section className="mb-5 grid gap-3 md:grid-cols-3">
        {[
          ['待跟进客户', clients.length, '持续更新客户动作'],
          ['高优先级任务', 1, '建议今天收口'],
          ['已完成动作', 1, '保持交付节奏'],
        ].map(([label, value, desc]) => (
          <article key={label} className="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
            <span className="text-sm text-slate-500">{label}</span>
            <strong className="my-2 block text-3xl">{value}</strong>
            <small className="text-slate-500">{desc}</small>
          </article>
        ))}
      </section>

      <section className="grid gap-5 lg:grid-cols-[1.7fr_0.8fr]">
        <div className="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
          <div className="mb-4 flex items-center justify-between">
            <h2 className="m-0 text-xl font-bold">客户跟进</h2>
            <span className="text-sm text-slate-500">{clients.length} 条</span>
          </div>
          <div className="grid gap-3">
            {clients.map(([name, stage, action, dueAt]) => (
              <article key={`${name}-${dueAt}`} className="rounded-lg border border-slate-100 bg-slate-50 p-4">
                <div className="flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
                  <div>
                    <h3 className="m-0 text-base font-semibold">{name}</h3>
                    <p className="mt-1 text-sm text-slate-600">{action}</p>
                  </div>
                  <div className="flex flex-wrap gap-2 text-sm text-slate-500">
                    <span className="rounded-full bg-blue-50 px-3 py-1 font-semibold text-blue-700">{stage}</span>
                    <span>{dueAt}</span>
                  </div>
                </div>
              </article>
            ))}
          </div>
        </div>
        <aside className="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
          <h2 className="m-0 mb-4 text-xl font-bold">待办事项</h2>
          <ul className="m-0 grid list-none gap-3 p-0">
            {tasks.map(([priority, title, status]) => (
              <li key={title} className="flex gap-3 border-b border-slate-100 pb-3 last:border-b-0">
                <span className="h-fit rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold">{priority}</span>
                <div>
                  <strong className="block">{title}</strong>
                  <small className="text-slate-500">{status}</small>
                </div>
              </li>
            ))}
          </ul>
        </aside>
      </section>
    </main>
  )
}

<% if (extras.includes('react-router')) { %>function WorkOrdersPage() {
  return (
    <main className="mx-auto w-full max-w-4xl px-5 py-8 text-slate-900">
      <section className="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
        <div className="mb-4 flex items-center justify-between">
          <h1 className="m-0 text-3xl font-bold">工单队列</h1>
          <span className="text-sm text-slate-500">3 个待处理</span>
        </div>
        {['设备巡检反馈', '合同开票咨询', '门店物料补发'].map((title) => (
          <article key={title} className="border-t border-slate-100 py-4">
            <h2 className="m-0 text-base font-semibold">{title}</h2>
            <p className="mt-1 text-sm text-slate-500">已分配负责人，等待下一步处理。</p>
          </article>
        ))}
      </section>
    </main>
  )
}

function App() {
  return (
    <BrowserRouter>
      <nav className="flex gap-2 px-5 pt-4">
        <NavLink className={({ isActive }) => `rounded-lg px-4 py-2 ${isActive ? 'bg-slate-900 text-white' : 'text-slate-600'}`} to="/">工作台</NavLink>
        <NavLink className={({ isActive }) => `rounded-lg px-4 py-2 ${isActive ? 'bg-slate-900 text-white' : 'text-slate-600'}`} to="/work-orders">工单</NavLink>
      </nav>
      <Routes>
        <Route path="/" element={<DashboardPage />} />
        <Route path="/work-orders" element={<WorkOrdersPage />} />
      </Routes>
    </BrowserRouter>
  )
}
<% } else { %>function App() {
  return <DashboardPage />
}
<% } %>

export default App
