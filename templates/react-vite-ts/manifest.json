{
  "key": "react-vite-ts",
  "name": "React + Vite + TypeScript",
  "description": "适合中小型前端应用，React 工程开箱即用",
  "version": "1.0.0",
  "schemaVersion": "1.0",
  "framework": "react",
  "requiredPm": null,
  "forbiddenPm": [],
  "requiredEnv": {
    "node": ">=18.0.0"
  },
  "optionalEnv": {},
  "supportedFeatures": [
    "eslint",
    "prettier",
    "husky",
    "agents",
    "coding-rules"
  ],
  "defaultFeatures": [
    "eslint",
    "prettier",
    "husky",
    "agents",
    "coding-rules"
  ],
  "features": {
    "eslint": {
      "label": "ESLint",
      "hint": "代码质量检查",
      "default": true,
      "artifacts": [
        "eslint.config.js"
      ]
    },
    "prettier": {
      "label": "Prettier",
      "hint": "代码格式化",
      "default": true,
      "artifacts": [
        ".prettierrc"
      ]
    },
    "husky": {
      "label": "commitlint + Husky",
      "hint": "提交信息校验",
      "default": true,
      "artifacts": [
        ".husky",
        "commitlint.config.js"
      ],
      "postActions": [
        "husky.install",
        "husky.chmod"
      ]
    },
    "agents": {
      "label": "AGENTS.md",
      "hint": "AI 协作约定",
      "default": true,
      "artifacts": [
        "AGENTS.md"
      ]
    },
    "coding-rules": {
      "label": "coding-rules.md",
      "hint": "团队代码规范",
      "default": true,
      "artifacts": [
        "coding-rules.md"
      ]
    }
  },
  "extras": [
    {
      "key": "react-router",
      "label": "React Router v6",
      "default": false,
      "source": "inline",
      "detectDependencies": [
        "react-router-dom"
      ]
    },
    {
      "key": "tailwind",
      "label": "Tailwind CSS v3",
      "default": false,
      "source": "file",
      "templatePath": "tailwind",
      "artifacts": [
        "tailwind.config.cjs",
        "postcss.config.cjs",
        "src/index.css"
      ]
    }
  ],
  "subPrompts": [],
  "devScript": "dev",
  "buildScript": "build",
  "devPort": 5173,
  "upgrade": {
    "managedFiles": [
      "tsconfig.json",
      "tsconfig.node.json",
      "eslint.config.js",
      "vite.config.ts",
      ".prettierrc",
      "commitlint.config.js"
    ]
  },
  "integrationTest": {
    "skipBuild": false,
    "skipDevServer": false,
    "installWorkspaces": [
      "."
    ],
    "buildWorkspace": "."
  }
}
