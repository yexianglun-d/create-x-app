<% if (extras.includes('react-router')) { %>import { NavLink, Route, Routes } from 'react-router-dom'
<% } %>
function HomePage() {
  return (
    <div className="page">
      <h1><%= projectName %></h1>
      <p className="subtitle">React + Vite + TypeScript 项目已就绪</p>
      <div className="actions">
        <a className="btn primary" href="https://vitejs.dev/guide/" target="_blank" rel="noreferrer">
          Vite 文档
        </a>
        <a className="btn" href="https://react.dev" target="_blank" rel="noreferrer">
          React 文档
        </a>
      </div>
    </div>
  )
}
<% if (extras.includes('react-router')) { %>
function AboutPage() {
  return (
    <div className="page">
      <h2>关于</h2>
      <p>这是一个使用 React Router 的 SPA 示例页面。</p>
    </div>
  )
}

<% } %>
export default function App() {
<% if (extras.includes('react-router')) { %>
  return (
    <>
      <nav className="nav">
        <NavLink to="/" end>首页</NavLink>
        <NavLink to="/about">关于</NavLink>
      </nav>
      <main className="container">
        <Routes>
          <Route path="/" element={<HomePage />} />
          <Route path="/about" element={<AboutPage />} />
        </Routes>
      </main>
    </>
  )
<% } else { %>
  return (
    <main className="container">
      <HomePage />
    </main>
  )
<% } %>
}
