{
  "key": "react-admin",
  "name": "React 后台管理系统",
  "description": "开箱即用的后台管理脚手架：登录认证、路由守卫、Antd 布局、请求封装、状态管理，拿来就能填业务页面",
  "tags": ["react", "antd", "zustand", "admin", "dashboard"],
  "useCases": [
    "企业后台管理系统（运营/客服/ERP/CRM）",
    "需要登录 + 路由守卫 + Antd 布局的中后台项目",
    "想直接获得可运行的后台骨架，在 Dashboard 填入自己的页面"
  ],
  "notFor": [
    "只需最简 Vite + React 脚手架 → react-vite-ts",
    "需要 Next.js SSR 方案 → nextjs-ts"
  ],
  "version": "1.0.0",
  "schemaVersion": "1.0",
  "framework": "react",
  "requirements": {
    "node": ">=18.0.0",
    "packageManagers": [
      "npm",
      "pnpm",
      "yarn"
    ]
  },
  "requiredPm": null,
  "forbiddenPm": [],
  "requiredEnv": {
    "node": ">=18.0.0"
  },
  "optionalEnv": {},
  "supportedFeatures": [
    "eslint",
    "prettier",
    "husky",
    "agents",
    "coding-rules",
    "ai-native"
  ],
  "defaultFeatures": [
    "eslint",
    "prettier",
    "husky",
    "agents",
    "coding-rules"
  ],
  "features": {
    "eslint": {
      "label": "ESLint",
      "hint": "代码质量检查",
      "default": true,
      "artifacts": [
        "eslint.config.js"
      ]
    },
    "prettier": {
      "label": "Prettier",
      "hint": "代码格式化",
      "default": true,
      "artifacts": [
        ".prettierrc"
      ]
    },
    "husky": {
      "label": "commitlint + Husky",
      "hint": "提交信息校验",
      "default": true,
      "artifacts": [
        ".husky",
        "commitlint.config.js"
      ],
      "postActions": [
        "husky.install",
        "husky.chmod"
      ]
    },
    "agents": {
      "label": "AGENTS.md",
      "hint": "AI 协作约定",
      "default": true,
      "artifacts": [
        "AGENTS.md"
      ]
    },
    "coding-rules": {
      "label": "coding-rules.md",
      "hint": "团队代码规范",
      "default": true,
      "artifacts": [
        "coding-rules.md"
      ]
    },
    "ai-native": {
      "label": "AI-native 工程规范",
      "hint": "Cursor / Claude / Copilot / MCP / ADR / Prompt 文件",
      "default": false,
      "artifacts": [
        ".cursor/rules/create-x-app.mdc",
        "CLAUDE.md",
        ".github/copilot-instructions.md",
        ".mcp.example.json",
        "docs/adr/0001-project-conventions.md",
        "docs/prompts/pr-review.md",
        "docs/prompts/commit-message.md"
      ]
    }
  },
  "extras": [
    {
      "key": "tailwind",
      "label": "Tailwind CSS v3",
      "default": false,
      "source": "inline",
      "artifacts": [
        "postcss.config.cjs",
        "tailwind.config.cjs"
      ]
    },
    {
      "key": "i18n",
      "label": "国际化（i18next）",
      "default": false,
      "source": "inline",
      "artifacts": [
        "src/i18n.ts"
      ],
      "detectDependencies": [
        "i18next"
      ]
    }
  ],
  "subPrompts": [],
  "devScript": "dev",
  "buildScript": "build",
  "devPort": 5173,
  "upgrade": {
    "managedFiles": [
      "tsconfig.json",
      "tsconfig.node.json",
      "eslint.config.js",
      "vite.config.ts",
      ".prettierrc",
      "commitlint.config.js",
      "postcss.config.cjs",
      "tailwind.config.cjs"
    ]
  },
  "integrationTest": {
    "skipBuild": false,
    "skipDevServer": false,
    "installWorkspaces": [
      "."
    ],
    "buildWorkspace": "."
  }
}
