export type AppCopyKey = keyof typeof fallbackCopy

<% if (extras.includes('i18n')) { %>import { useTranslation } from 'react-i18next'

export function useAppCopy() {
  const { t } = useTranslation()

  return {
    copy(key: AppCopyKey) {
      return t(key, fallbackCopy[key])
    },
  }
}
<% } else { %>export function useAppCopy() {
  return {
    copy(key: AppCopyKey) {
      return fallbackCopy[key]
    },
  }
}
<% } %>
