const fallbackCopy = {
  'brand.name': '<%= projectName %>',
  'brand.desc': '运营管理台',
  'shell.title': '运营工作台',
  'shell.desc': '集中处理客户跟进、服务工单和审批任务。',
  'dashboard.title': '今日运营概览',
  'dashboard.desc': '按负责人和优先级快速定位需要推进的客户事项。',
  'login.title': '登录运营管理台',
  'login.desc': '进入后可处理客户跟进、服务工单和审批任务。',
  'login.cardTitle': '账号登录',
  'login.submit': '登录',
  'notFound.title': '页面不存在',
  'notFound.desc': '当前访问的地址没有对应页面，请返回工作台继续操作。',
  'notFound.action': '返回工作台'
} as const

export type AppCopyKey = keyof typeof fallbackCopy

<% if (extras.includes('i18n')) { %>import { useTranslation } from 'react-i18next'

export function useAppCopy() {
  const { t } = useTranslation()

  return {
    copy(key: AppCopyKey) {
      return t(key, fallbackCopy[key])
    },
  }
}
<% } else { %>export function useAppCopy() {
  return {
    copy(key: AppCopyKey) {
      return fallbackCopy[key]
    },
  }
}
<% } %>
