<% if (extras.includes('tailwind')) { %>@tailwind base;
@tailwind components;
@tailwind utilities;

<% } %>:root {
  color: #172033;
  background: #f5f7fb;
  font-synthesis: none;
  text-rendering: optimizeLegibility;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

* {
  box-sizing: border-box;
}

html,
body,
#root {
  min-height: 100%;
}

body {
  margin: 0;
  min-width: 320px;
  min-height: 100vh;
  color: #172033;
  background: #f5f7fb;
}

a {
  color: inherit;
}

.admin-app,
.admin-shell {
  min-height: 100vh;
}

.admin-sider.ant-layout-sider {
  background: #172033;
  border-right: 1px solid #263247;
}

.admin-brand {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 18px 18px 14px;
}

.admin-brand-mark {
  display: grid;
  height: 38px;
  width: 38px;
  place-items: center;
  border-radius: 8px;
  background: #ffffff;
  color: #172033;
  font-size: 15px;
  font-weight: 800;
}

.admin-brand-text {
  min-width: 0;
}

.admin-brand-title {
  margin: 0;
  color: #ffffff;
  font-size: 16px;
  font-weight: 700;
}

.admin-brand-desc {
  margin: 4px 0 0;
  color: rgba(255, 255, 255, 0.64);
  font-size: 12px;
}

.admin-menu.ant-menu {
  background: transparent;
  border-inline-end: none;
  color: rgba(255, 255, 255, 0.76);
}

.admin-menu.ant-menu .ant-menu-item {
  height: 44px;
  line-height: 44px;
  margin: 4px 10px;
  border-radius: 8px;
}

.admin-menu.ant-menu .ant-menu-item-selected {
  background: #2563eb;
  color: #ffffff;
}

.admin-content-layout {
  background: #f5f7fb;
}

.admin-header {
  display: flex;
  align-items: center;
  padding: 16px 24px;
  background: #f5f7fb;
  height: auto;
  line-height: normal;
}

.admin-header-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  width: 100%;
  border: 1px solid #dde5ef;
  border-radius: 8px;
  padding: 16px 18px;
  background: #ffffff;
  box-shadow: 0 12px 30px rgba(20, 32, 54, 0.06);
}

.admin-header-title {
  margin: 0 0 4px;
  color: #101828;
  font-size: 24px;
  font-weight: 700;
}

.admin-header-desc {
  margin: 0;
  color: #667085;
}

.admin-user-panel {
  display: flex;
  align-items: center;
  gap: 10px;
}

.admin-user-meta {
  text-align: right;
}

.admin-user-name {
  margin: 0;
  color: #172033;
  font-size: 14px;
  font-weight: 700;
}

.admin-user-role {
  margin: 3px 0 0;
  color: #667085;
  font-size: 12px;
}

.admin-content {
  padding: 0 24px 24px;
  background: #f5f7fb;
}

.admin-content-inner {
  min-height: calc(100vh - 128px);
}

.dashboard-grid {
  display: grid;
  gap: 16px;
}

.dashboard-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16px;
}

.dashboard-header h2 {
  margin: 0 0 6px;
  color: #101828;
  font-size: 26px;
}

.dashboard-header p {
  margin: 0;
  color: #667085;
}

.table-toolbar {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  justify-content: space-between;
  margin-bottom: 14px;
}

.dashboard-bottom-grid {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(320px, 0.8fr);
  gap: 16px;
}

.muted-text {
  color: #667085;
  font-size: 13px;
}

.login-page {
  display: grid;
  min-height: 100vh;
  grid-template-columns: minmax(0, 1fr) minmax(360px, 440px);
  gap: 24px;
  align-items: center;
  width: min(1040px, 100%);
  margin: 0 auto;
  padding: 24px;
}

.login-intro,
.login-panel {
  border: 1px solid #dde5ef;
  border-radius: 8px;
  background: #ffffff;
  box-shadow: 0 12px 30px rgba(20, 32, 54, 0.06);
}

.login-intro {
  padding: 32px;
}

.login-icon {
  display: inline-flex;
  margin-bottom: 18px;
  color: #2563eb;
  font-size: 36px;
}

.login-intro h1.ant-typography {
  margin: 0 0 12px;
  color: #101828;
  font-size: 42px;
}

.login-intro .ant-typography {
  color: #667085;
  font-size: 16px;
}

.login-benefits {
  display: grid;
  gap: 10px;
  margin: 24px 0 0;
  padding: 0;
  list-style: none;
}

.login-benefits li {
  border-left: 3px solid #2563eb;
  padding-left: 12px;
  color: #344054;
  font-weight: 600;
}

.login-panel {
  padding: 24px;
}

.login-panel-head h3.ant-typography {
  margin: 0 0 8px;
}

@media (max-width: 960px) {
  .login-page,
  .dashboard-bottom-grid {
    grid-template-columns: 1fr;
  }

  .admin-header-card,
  .dashboard-header {
    align-items: stretch;
    flex-direction: column;
  }

  .admin-user-panel {
    justify-content: flex-start;
  }
}

@media (max-width: 720px) {
  .admin-header,
  .admin-content {
    padding-left: 14px;
    padding-right: 14px;
  }

  .admin-user-meta {
    display: none;
  }
}
