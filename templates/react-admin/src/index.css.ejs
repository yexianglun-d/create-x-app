<% if (extras.includes('tailwind')) { %>@tailwind base;
@tailwind components;
@tailwind utilities;

<% } %>:root {
  color: #e5eefb;
  background:
    radial-gradient(circle at top left, rgba(37, 99, 235, 0.18), transparent 34%),
    radial-gradient(circle at bottom right, rgba(15, 118, 110, 0.18), transparent 36%),
    linear-gradient(180deg, #081121 0%, #0f172a 100%);
  font-synthesis: none;
  text-rendering: optimizeLegibility;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

* {
  box-sizing: border-box;
}

html,
body,
#root {
  min-height: 100%;
}

body {
  margin: 0;
  min-width: 320px;
  min-height: 100vh;
  color: #e5eefb;
  background:
    radial-gradient(circle at top left, rgba(37, 99, 235, 0.18), transparent 34%),
    radial-gradient(circle at bottom right, rgba(15, 118, 110, 0.18), transparent 36%),
    linear-gradient(180deg, #081121 0%, #0f172a 100%);
}

a {
  color: inherit;
}

.admin-app {
  min-height: 100vh;
}

.admin-shell {
  min-height: 100vh;
  background: transparent;
}

.admin-sider.ant-layout-sider {
  background: rgba(9, 14, 27, 0.86);
  border-right: 1px solid rgba(148, 163, 184, 0.14);
  backdrop-filter: blur(18px);
}

.admin-brand {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 18px 20px 14px;
}

.admin-brand-mark {
  display: grid;
  height: 40px;
  width: 40px;
  place-items: center;
  border-radius: 14px;
  background: linear-gradient(135deg, #2563eb 0%, #0f766e 100%);
  color: white;
  font-size: 18px;
  font-weight: 700;
  box-shadow: 0 16px 32px rgba(37, 99, 235, 0.22);
}

.admin-brand-text {
  min-width: 0;
}

.admin-brand-title {
  margin: 0;
  color: #f8fafc;
  font-size: 16px;
  font-weight: 700;
}

.admin-brand-desc {
  margin: 4px 0 0;
  color: rgba(226, 232, 240, 0.7);
  font-size: 12px;
}

.admin-menu.ant-menu {
  background: transparent;
  border-inline-end: none;
  color: rgba(226, 232, 240, 0.88);
}

.admin-menu.ant-menu .ant-menu-item {
  height: 52px;
  line-height: 52px;
  margin: 4px 12px;
  border-radius: 14px;
}

.admin-menu.ant-menu .ant-menu-item-selected {
  background: linear-gradient(135deg, rgba(37, 99, 235, 0.22), rgba(14, 165, 233, 0.16));
  color: #ffffff;
}

.admin-content-layout {
  background: transparent;
}

.admin-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  padding: 18px 28px;
  background: transparent;
}

.admin-header-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  width: 100%;
  padding: 16px 20px;
  border: 1px solid rgba(148, 163, 184, 0.14);
  border-radius: 24px;
  background: rgba(15, 23, 42, 0.68);
  backdrop-filter: blur(18px);
  box-shadow: 0 18px 60px rgba(2, 8, 23, 0.32);
}

.admin-header-copy {
  min-width: 0;
}

.admin-header-kicker {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 6px 10px;
  border-radius: 999px;
  background: rgba(37, 99, 235, 0.16);
  color: #93c5fd;
  font-size: 12px;
}

.admin-header-title {
  margin: 10px 0 4px;
  color: #f8fafc;
  font-size: 26px;
  font-weight: 700;
}

.admin-header-desc {
  margin: 0;
  color: rgba(226, 232, 240, 0.72);
}

.admin-user-panel {
  display: flex;
  align-items: center;
  gap: 12px;
}

.admin-user-meta {
  text-align: right;
}

.admin-user-name {
  margin: 0;
  color: #f8fafc;
  font-size: 15px;
  font-weight: 600;
}

.admin-user-role {
  margin: 4px 0 0;
  color: rgba(226, 232, 240, 0.66);
  font-size: 12px;
}

.admin-content {
  padding: 0 28px 28px;
  background: transparent;
}

.admin-content-inner {
  min-height: calc(100vh - 148px);
}

.dashboard-grid {
  display: grid;
  gap: 20px;
}

.dashboard-summary-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 18px;
}

.dashboard-card.ant-card,
.dashboard-table.ant-card,
.dashboard-side-card.ant-card,
.login-panel.ant-card {
  border: 1px solid rgba(148, 163, 184, 0.14);
  background: rgba(15, 23, 42, 0.72);
  box-shadow: 0 18px 60px rgba(2, 8, 23, 0.28);
}

.dashboard-hero.ant-card {
  overflow: hidden;
  border: 1px solid rgba(148, 163, 184, 0.14);
  background:
    radial-gradient(circle at top left, rgba(14, 165, 233, 0.18), transparent 28%),
    linear-gradient(135deg, rgba(15, 23, 42, 0.88), rgba(30, 41, 59, 0.78));
  box-shadow: 0 18px 60px rgba(2, 8, 23, 0.32);
}

.dashboard-hero-title {
  margin: 0 0 12px;
  color: #f8fafc;
  font-size: 30px;
  font-weight: 700;
}

.dashboard-hero-desc {
  max-width: 720px;
  margin: 0;
  color: rgba(226, 232, 240, 0.78);
  line-height: 1.7;
}

.dashboard-main-grid {
  display: grid;
  grid-template-columns: minmax(0, 2fr) minmax(300px, 1fr);
  gap: 20px;
}

.dashboard-kpi {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
}

.dashboard-kpi-label {
  margin: 0 0 8px;
  color: rgba(226, 232, 240, 0.72);
  font-size: 13px;
}

.dashboard-kpi-value {
  margin: 0;
  color: #f8fafc;
  font-size: 28px;
  font-weight: 700;
}

.dashboard-kpi-footnote {
  margin: 10px 0 0;
  color: rgba(226, 232, 240, 0.6);
  font-size: 12px;
}

.dashboard-kpi-icon {
  display: grid;
  height: 52px;
  width: 52px;
  place-items: center;
  border-radius: 16px;
  background: rgba(37, 99, 235, 0.14);
  color: #93c5fd;
  font-size: 22px;
}

.dashboard-side-stack {
  display: grid;
  gap: 20px;
}

.dashboard-request-result {
  margin-top: 14px;
  padding: 12px 14px;
  border-radius: 14px;
  background: rgba(15, 118, 110, 0.12);
  color: #d1fae5;
  font-size: 13px;
  line-height: 1.7;
  white-space: pre-wrap;
}

.login-page {
  display: grid;
  min-height: 100vh;
  place-items: center;
  padding: 24px;
}

.login-shell {
  display: grid;
  width: min(1040px, 100%);
  gap: 24px;
  grid-template-columns: minmax(0, 1.1fr) minmax(360px, 440px);
}

.login-showcase {
  padding: 32px;
  border: 1px solid rgba(148, 163, 184, 0.14);
  border-radius: 28px;
  background:
    radial-gradient(circle at top left, rgba(37, 99, 235, 0.18), transparent 30%),
    linear-gradient(180deg, rgba(15, 23, 42, 0.82), rgba(15, 23, 42, 0.66));
  backdrop-filter: blur(22px);
}

.login-kicker {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 8px 12px;
  border-radius: 999px;
  background: rgba(14, 165, 233, 0.14);
  color: #7dd3fc;
  font-size: 12px;
}

.login-title {
  margin: 18px 0 12px;
  color: #f8fafc;
  font-size: 42px;
  line-height: 1.15;
}

.login-desc {
  max-width: 520px;
  color: rgba(226, 232, 240, 0.76);
  line-height: 1.8;
}

.login-metric-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14px;
  margin-top: 28px;
}

.login-metric {
  padding: 16px;
  border-radius: 18px;
  background: rgba(15, 23, 42, 0.46);
}

.login-metric-value {
  margin: 0;
  color: #f8fafc;
  font-size: 22px;
  font-weight: 700;
}

.login-metric-label {
  margin: 8px 0 0;
  color: rgba(226, 232, 240, 0.64);
  font-size: 12px;
}

.login-panel.ant-card {
  border-radius: 28px;
}

.login-panel .ant-card-body {
  padding: 28px;
}

.not-found-card.ant-card {
  max-width: 560px;
  margin: 0 auto;
  border: 1px solid rgba(148, 163, 184, 0.14);
  background: rgba(15, 23, 42, 0.72);
}

.ant-statistic .ant-statistic-title {
  color: rgba(226, 232, 240, 0.68);
}

.ant-statistic .ant-statistic-content,
.ant-card .ant-card-head-title,
.ant-table-wrapper,
.ant-form,
.ant-typography {
  color: inherit;
}

@media (max-width: 960px) {
  .dashboard-main-grid,
  .login-shell {
    grid-template-columns: 1fr;
  }

  .admin-header-card {
    align-items: flex-start;
    flex-direction: column;
  }

  .admin-user-panel {
    width: 100%;
    justify-content: space-between;
  }
}

@media (max-width: 640px) {
  .admin-header,
  .admin-content {
    padding-left: 16px;
    padding-right: 16px;
  }

  .login-showcase {
    padding: 24px;
  }

  .login-title {
    font-size: 34px;
  }

  .login-metric-grid {
    grid-template-columns: 1fr;
  }
}
