{
  "key": "monorepo",
  "name": "全栈 Monorepo（Turborepo）",
  "description": "Turborepo + pnpm workspace，前端 / API / 共享类型三包联动",
  "version": "1.0.0",
  "schemaVersion": "1.0",
  "framework": "react",
  "requirements": {
    "node": ">=18.0.0",
    "packageManagers": [
      "pnpm"
    ]
  },
  "requiredPm": "pnpm",
  "forbiddenPm": [
    "npm",
    "yarn"
  ],
  "requiredEnv": {
    "node": ">=18.0.0"
  },
  "optionalEnv": {},
  "supportedFeatures": [
    "eslint",
    "prettier",
    "husky",
    "agents",
    "coding-rules"
  ],
  "defaultFeatures": [
    "eslint",
    "prettier",
    "agents",
    "coding-rules"
  ],
  "features": {
    "eslint": {
      "label": "ESLint",
      "hint": "代码质量检查",
      "default": true,
      "artifacts": [
        "eslint.config.js"
      ]
    },
    "prettier": {
      "label": "Prettier",
      "hint": "代码格式化",
      "default": true,
      "artifacts": [
        ".prettierrc"
      ]
    },
    "husky": {
      "label": "commitlint + Husky",
      "hint": "提交信息校验",
      "default": false,
      "artifacts": [
        ".husky",
        "commitlint.config.js"
      ],
      "postActions": [
        "husky.install",
        "husky.chmod"
      ]
    },
    "agents": {
      "label": "AGENTS.md",
      "hint": "AI 协作约定",
      "default": true,
      "artifacts": [
        "AGENTS.md"
      ]
    },
    "coding-rules": {
      "label": "coding-rules.md",
      "hint": "团队代码规范",
      "default": true,
      "artifacts": [
        "coding-rules.md"
      ]
    }
  },
  "extras": [],
  "subPrompts": [],
  "devScript": "dev",
  "buildScript": "build",
  "devPort": 5173,
  "upgrade": {
    "managedFiles": [
      "tsconfig.base.json",
      "turbo.json",
      "pnpm-workspace.yaml",
      "eslint.config.js",
      ".prettierrc",
      "commitlint.config.js",
      "apps/api/tsconfig.json",
      "apps/web/tsconfig.json",
      "apps/web/vite.config.ts",
      "packages/shared/tsconfig.json"
    ]
  },
  "integrationTest": {
    "skipBuild": false,
    "skipDevServer": false,
    "installWorkspaces": [
      "."
    ],
    "buildWorkspace": "."
  }
}
