import { useEffect, useState } from 'react'
import type { ApiResponse, TaskItem, DashboardSummary } from '@<%= projectName %>/shared'

interface DashboardPayload {
  summary: DashboardSummary
  tasks: TaskItem[]
}

const statusLabels: Record<TaskItem['status'], string> = {
  todo: '待办',
  in_progress: '进行中',
  review: '评审中',
  done: '已完成',
}

const priorityLabels: Record<TaskItem['priority'], string> = {
  high: '高',
  medium: '中',
  low: '低',
}

const priorityColors: Record<TaskItem['priority'], string> = {
  high: '#b42318',
  medium: '#92400e',
  low: '#137a45',
}

export default function App() {
  const [dashboard, setDashboard] = useState<DashboardPayload | null>(null)
  const [statusMessage, setStatusMessage] = useState('正在加载任务数据...')

  useEffect(() => {
    void fetch('/api/dashboard')
      .then(async (response) => response.json() as Promise<ApiResponse<DashboardPayload>>)
      .then((payload) => {
        setDashboard(payload.data)
        setStatusMessage('数据已同步')
      })
      .catch(() => {
        setStatusMessage('API 服务未启动，运行 pnpm dev 后会自动联调。')
      })
  }, [])

  const summary = dashboard?.summary ?? {
    totalTasks: 0,
    inProgress: 0,
    highPriority: 0,
  }
  const tasks = dashboard?.tasks ?? []

  return (
    <main
      style={{
        minHeight: '100vh',
        background: '#f8fafc',
        fontFamily: 'system-ui, -apple-system, sans-serif',
        color: '#1e293b',
      }}
    >
      <section style={{ maxWidth: 960, margin: '0 auto', padding: '40px 24px' }}>
        <p style={{ fontSize: 14, fontWeight: 600, color: '#64748b', marginBottom: 8 }}>
          @<%= projectName %>/web
        </p>
        <h1 style={{ fontSize: 40, fontWeight: 700, lineHeight: 1.2 }}>任务管理仪表盘</h1>
        <p style={{ marginTop: 12, maxWidth: 640, color: '#475569', lineHeight: 1.7 }}>
          此界面演示 monorepo 中前后端共享类型的典型用法。你可以继续扩展任务过滤、拖拽排序、多看板视图等功能。
        </p>
        <p style={{ marginTop: 12, fontSize: 13, color: '#94a3b8' }}>{statusMessage}</p>
      </section>

      <section
        style={{
          display: 'grid',
          gridTemplateColumns: 'repeat(auto-fit, minmax(200px, 1fr))',
          gap: 16,
          maxWidth: 960,
          margin: '0 auto 32px',
          padding: '0 24px',
        }}
      >
        {[
          { label: '总任务数', value: summary.totalTasks, hint: '持续更新' },
          { label: '进行中', value: summary.inProgress, hint: '当前活跃任务' },
          { label: '高优先级', value: summary.highPriority, hint: '需要优先处理' },
        ].map((card) => (
          <article
            key={card.label}
            style={{
              background: '#fff',
              borderRadius: 12,
              border: '1px solid #e2e8f0',
              padding: 20,
              boxShadow: '0 1px 3px rgba(15,23,42,.04)',
            }}
          >
            <span style={{ fontSize: 13, color: '#64748b' }}>{card.label}</span>
            <strong style={{ display: 'block', fontSize: 32, marginTop: 4 }}>{card.value}</strong>
            <small style={{ color: '#94a3b8' }}>{card.hint}</small>
          </article>
        ))}
      </section>

      <section style={{ maxWidth: 960, margin: '0 auto', padding: '0 24px 48px' }}>
        <div
          style={{
            background: '#fff',
            borderRadius: 12,
            border: '1px solid #e2e8f0',
            padding: 24,
            boxShadow: '0 1px 3px rgba(15,23,42,.04)',
          }}
        >
          <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', marginBottom: 16 }}>
            <h2 style={{ fontSize: 18, fontWeight: 600 }}>任务列表</h2>
            <span style={{ fontSize: 13, color: '#64748b' }}>{tasks.length} 条</span>
          </div>

          {tasks.length === 0 ? (
            <p style={{ color: '#94a3b8' }}>暂无任务数据。启动后端 API 后会自动加载。</p>
          ) : (
            <div style={{ display: 'grid', gap: 12 }}>
              {tasks.map((task) => (
                <article
                  key={task.id}
                  style={{
                    display: 'flex',
                    justifyContent: 'space-between',
                    alignItems: 'center',
                    border: '1px solid #f1f5f9',
                    borderRadius: 10,
                    padding: 16,
                    background: '#f8fafc',
                  }}
                >
                  <div>
                    <strong style={{ fontSize: 15 }}>{task.title}</strong>
                    <p style={{ fontSize: 13, color: '#64748b', marginTop: 4 }}>
                      {task.description}
                    </p>
                  </div>
                  <div style={{ display: 'flex', alignItems: 'center', gap: 8, fontSize: 13, color: '#64748b' }}>
                    <span style={{ fontSize: 12, color: priorityColors[task.priority] }}>
                      {priorityLabels[task.priority]}
                    </span>
                    <span>{task.assignee}</span>
                    <span
                      style={{
                        padding: '2px 8px',
                        borderRadius: 6,
                        background: '#eff6ff',
                        color: '#1d4ed8',
                        fontSize: 12,
                      }}
                    >
                      {statusLabels[task.status]}
                    </span>
                    <span>{task.dueAt}</span>
                  </div>
                </article>
              ))}
            </div>
          )}
        </div>
      </section>
    </main>
  )
}
