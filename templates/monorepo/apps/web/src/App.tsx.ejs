import { useEffect, useState } from 'react'
import type { ApiResponse, CustomerAction, WorkspaceSummary } from '@<%= projectName %>/shared'

interface WorkspacePayload {
  summary: WorkspaceSummary
  actions: CustomerAction[]
}

const stageLabels: Record<CustomerAction['stage'], string> = {
  new: '新建',
  contacted: '已沟通',
  proposal: '方案中',
  contract: '合同确认',
}

const priorityLabels: Record<CustomerAction['priority'], string> = {
  high: '高',
  medium: '中',
  low: '低',
}

const priorityColors: Record<CustomerAction['priority'], string> = {
  high: '#b42318',
  medium: '#92400e',
  low: '#137a45',
}

export default function App() {
  const [workspace, setWorkspace] = useState<WorkspacePayload | null>(null)
  const [statusMessage, setStatusMessage] = useState('正在加载今日业务数据...')

  useEffect(() => {
    void fetch('/api/workspace')
      .then(async (response) => response.json() as Promise<ApiResponse<WorkspacePayload>>)
      .then((payload) => {
        setWorkspace(payload.data)
        setStatusMessage('数据已同步')
      })
      .catch(() => {
        setStatusMessage('API 服务未启动，运行 pnpm dev 后会自动联调。')
      })
  }, [])

  const summary = workspace?.summary ?? {
    openActions: 0,
    highPriorityActions: 0,
    serviceTickets: 0,
  }
  const actions = workspace?.actions ?? []

  return (
    <main
      style={{
        minHeight: '100vh',
        padding: 36,
        boxSizing: 'border-box',
        color: '#172033',
        fontFamily: '"SF Pro Display", "PingFang SC", "Segoe UI", sans-serif',
        background: '#f5f7fb',
      }}
    >
      <section style={{ maxWidth: 860, marginBottom: 24 }}>
        <p style={{ margin: '0 0 10px', color: '#667085', fontWeight: 700 }}><%= projectName %></p>
        <h1 style={{ margin: '0 0 12px', color: '#101828', fontSize: 44, lineHeight: 1.08 }}>
          业务协作工作区
        </h1>
        <p style={{ margin: 0, color: '#5d6678', lineHeight: 1.8 }}>
          前端、API 和共享类型围绕同一套客户行动协议协作，适合作为全栈业务项目的起点。
        </p>
      </section>

      <section
        style={{
          display: 'grid',
          gap: 14,
          gridTemplateColumns: 'repeat(auto-fit, minmax(220px, 1fr))',
          marginBottom: 18,
        }}
      >
        {[
          ['待跟进客户', summary.openActions],
          ['高优先级事项', summary.highPriorityActions],
          ['服务工单', summary.serviceTickets],
        ].map(([label, value]) => (
          <article
            key={label}
            style={{
              border: '1px solid #dde5ef',
              borderRadius: 8,
              padding: 18,
              background: '#ffffff',
              boxShadow: '0 12px 30px rgba(20, 32, 54, 0.06)',
            }}
          >
            <span style={{ color: '#667085', fontSize: 13 }}>{label}</span>
            <strong style={{ display: 'block', marginTop: 8, fontSize: 32 }}>{value}</strong>
          </article>
        ))}
      </section>

      <section
        style={{
          border: '1px solid #dde5ef',
          borderRadius: 8,
          padding: 20,
          background: '#ffffff',
          boxShadow: '0 12px 30px rgba(20, 32, 54, 0.06)',
        }}
      >
        <div style={{ display: 'flex', justifyContent: 'space-between', gap: 16, marginBottom: 16 }}>
          <h2 style={{ margin: 0 }}>客户行动列表</h2>
          <span style={{ color: '#667085' }}>{statusMessage}</span>
        </div>

        {actions.length === 0 ? (
          <p style={{ margin: 0, color: '#667085' }}>暂无数据，API 启动后会显示客户行动。</p>
        ) : (
          <div style={{ display: 'grid', gap: 10 }}>
            {actions.map((action) => (
              <article
                key={action.id}
                style={{
                  display: 'flex',
                  justifyContent: 'space-between',
                  gap: 16,
                  border: '1px solid #e6ebf2',
                  borderRadius: 8,
                  padding: 14,
                  background: '#fbfcfe',
                }}
              >
                <div>
                  <h3 style={{ margin: '0 0 5px', fontSize: 16 }}>{action.customerName}</h3>
                  <p style={{ margin: 0, color: '#5d6678' }}>{action.nextAction}</p>
                </div>
                <div style={{ display: 'grid', justifyItems: 'end', gap: 5, minWidth: 120 }}>
                  <span style={{ color: '#2563eb', fontWeight: 700 }}>{stageLabels[action.stage]}</span>
                  <span style={{ color: priorityColors[action.priority], fontWeight: 700 }}>
                    {priorityLabels[action.priority]}优先级
                  </span>
                  <span style={{ color: '#667085' }}>{action.dueAt}</span>
                </div>
              </article>
            ))}
          </div>
        )}
      </section>
    </main>
  )
}
