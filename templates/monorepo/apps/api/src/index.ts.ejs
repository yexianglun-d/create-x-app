import express from 'express'
import type { ApiResponse, TaskItem, DashboardSummary } from '@<%= projectName %>/shared'

const app = express()
const port = Number(process.env.PORT ?? 3000)

const tasks: TaskItem[] = [
  {
    id: 'task-001',
    title: '完成需求分析文档',
    assignee: '张三',
    status: 'in_progress',
    priority: 'high',
    description: '整理需求清单并撰写分析报告',
    dueAt: '今天 17:00',
  },
  {
    id: 'task-002',
    title: '设计系统架构方案',
    assignee: '李四',
    status: 'review',
    priority: 'medium',
    description: '完成技术选型和架构设计',
    dueAt: '明天 10:30',
  },
  {
    id: 'task-003',
    title: '编写单元测试',
    assignee: '王五',
    status: 'todo',
    priority: 'low',
    description: '覆盖核心业务逻辑的测试用例',
    dueAt: '周五',
  },
]

function buildResponse<T>(data: T, message: string): ApiResponse<T> {
  return {
    code: 0,
    data,
    message,
  }
}

function buildSummary(): DashboardSummary {
  return {
    totalTasks: tasks.length,
    inProgress: tasks.filter((task) => task.status === 'in_progress').length,
    highPriority: tasks.filter((task) => task.priority === 'high').length,
  }
}

app.use(express.json())

app.get('/api/health', (_request, response) => {
  response.json(buildResponse({ status: 'ok' }, 'ready'))
})

app.get('/api/dashboard', (_request, response) => {
  response.json(buildResponse({
    summary: buildSummary(),
    tasks,
  }, 'ok'))
})

app.listen(port, () => {
  console.log(`@<%= projectName %>/api listening on http://localhost:${port}`)
})
