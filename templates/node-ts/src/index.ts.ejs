<% if (extras.includes('dotenv')) { %>import 'dotenv/config'
<% } %><% if (extras.includes('express')) { %>import express from 'express'

type Priority = 'high' | 'medium' | 'low'
type Stage = 'todo' | 'in_progress' | 'review' | 'done'

interface TaskItem {
  id: string
  title: string
  assignee: string
  stage: Stage
  priority: Priority
  nextStep: string
  dueAt: string
}

interface ApiResponse<T> {
  code: number
  data: T
  message: string
}

const DEFAULT_PORT = 3000
const app = express()
const taskItems: TaskItem[] = [
  {
    id: 't-1001',
    title: '完善项目文档',
    assignee: '张三',
    stage: 'in_progress',
    priority: 'high',
    nextStep: '补充 API 接口说明',
    dueAt: '今天 17:00',
  },
  {
    id: 't-1002',
    title: '单元测试覆盖',
    assignee: '李四',
    stage: 'review',
    priority: 'medium',
    nextStep: '补充边界用例',
    dueAt: '明天 10:30',
  },
]

function buildResponse<T>(data: T, message: string): ApiResponse<T> {
  return {
    code: 0,
    data,
    message,
  }
}

function resolvePort() {
  const portValue = process.env.PORT

  if (!portValue) {
    return DEFAULT_PORT
  }

  const parsedPort = Number(portValue)

  if (!Number.isInteger(parsedPort) || parsedPort <= 0) {
    throw new Error('环境变量 PORT 必须为正整数')
  }

  return parsedPort
}

function normalizeText(value: unknown) {
  return typeof value === 'string' ? value.trim() : ''
}

function normalizePriority(value: unknown): Priority {
  return value === 'high' || value === 'medium' || value === 'low' ? value : 'medium'
}

function createTask(payload: Record<string, unknown>): TaskItem {
  const title = normalizeText(payload.title)
  const nextStep = normalizeText(payload.nextStep)

  if (!title || !nextStep) {
    throw new Error('title 和 nextStep 为必填项')
  }

  return {
    id: `t-${Date.now()}`,
    title,
    assignee: normalizeText(payload.assignee) || '待分配',
    stage: 'todo',
    priority: normalizePriority(payload.priority),
    nextStep,
    dueAt: normalizeText(payload.dueAt) || '待定',
  }
}

app.use(express.json())

app.get('/api/health', (_request, response) => {
  response.json(buildResponse({
    service: process.env.SERVICE_NAME ?? '<%= projectName %>',
    status: 'ok',
  }, 'ready'))
})

app.get('/api/tasks', (_request, response) => {
  response.json(buildResponse(taskItems, 'loaded'))
})

app.post('/api/tasks', (request, response) => {
  try {
    const task = createTask(request.body as Record<string, unknown>)
    taskItems.unshift(task)
    response.status(201).json(buildResponse(task, 'created'))
  } catch (error) {
    response.status(400).json({
      code: 400,
      data: null,
      message: error instanceof Error ? error.message : '请求参数错误',
    })
  }
})

const port = resolvePort()

app.listen(port, () => {
  console.log(`API ready at http://localhost:${port}`)
})
<% } else { %>interface Task {
  title: string
  nextStep: string
}

const pendingTasks: Task[] = [
  {
    title: '完善项目文档',
    nextStep: '补充 API 接口说明',
  },
]

for (const task of pendingTasks) {
  console.log(`${task.title}: ${task.nextStep}`)
}
<% } %>
