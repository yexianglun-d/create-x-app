<% if (extras.includes('dotenv')) { %>import 'dotenv/config'
<% } %><% if (extras.includes('express')) { %>import express from 'express'

type Priority = 'high' | 'medium' | 'low'
type Stage = 'new' | 'contacted' | 'proposal' | 'contract'

interface CustomerAction {
  id: string
  customerName: string
  owner: string
  stage: Stage
  priority: Priority
  nextAction: string
  dueAt: string
}

interface ApiResponse<T> {
  code: number
  data: T
  message: string
}

const DEFAULT_PORT = 3000
const app = express()
const customerActions: CustomerAction[] = [
  {
    id: 'ca-1001',
    customerName: '华东渠道续约',
    owner: '林夏',
    stage: 'contract',
    priority: 'high',
    nextAction: '补齐采购审批附件',
    dueAt: '今天 17:00',
  },
  {
    id: 'ca-1002',
    customerName: '新门店上线支持',
    owner: '周南',
    stage: 'proposal',
    priority: 'medium',
    nextAction: '发送开店物料清单',
    dueAt: '明天 10:30',
  },
]

function buildResponse<T>(data: T, message: string): ApiResponse<T> {
  return {
    code: 0,
    data,
    message,
  }
}

function resolvePort() {
  const portValue = process.env.PORT

  if (!portValue) {
    return DEFAULT_PORT
  }

  const parsedPort = Number(portValue)

  if (!Number.isInteger(parsedPort) || parsedPort <= 0) {
    throw new Error('环境变量 PORT 必须为正整数')
  }

  return parsedPort
}

function normalizeText(value: unknown) {
  return typeof value === 'string' ? value.trim() : ''
}

function normalizePriority(value: unknown): Priority {
  return value === 'high' || value === 'medium' || value === 'low' ? value : 'medium'
}

function createCustomerAction(payload: Record<string, unknown>): CustomerAction {
  const customerName = normalizeText(payload.customerName)
  const nextAction = normalizeText(payload.nextAction)

  if (!customerName || !nextAction) {
    throw new Error('customerName 和 nextAction 为必填项')
  }

  return {
    id: `ca-${Date.now()}`,
    customerName,
    owner: normalizeText(payload.owner) || '待分配',
    stage: 'new',
    priority: normalizePriority(payload.priority),
    nextAction,
    dueAt: normalizeText(payload.dueAt) || '待定',
  }
}

app.use(express.json())

app.get('/api/health', (_request, response) => {
  response.json(buildResponse({
    service: process.env.SERVICE_NAME ?? '<%= projectName %>',
    status: 'ok',
  }, 'ready'))
})

app.get('/api/customer-actions', (_request, response) => {
  response.json(buildResponse(customerActions, 'loaded'))
})

app.post('/api/customer-actions', (request, response) => {
  try {
    const action = createCustomerAction(request.body as Record<string, unknown>)
    customerActions.unshift(action)
    response.status(201).json(buildResponse(action, 'created'))
  } catch (error) {
    response.status(400).json({
      code: 400,
      data: null,
      message: error instanceof Error ? error.message : '请求参数错误',
    })
  }
})

const port = resolvePort()

app.listen(port, () => {
  console.log(`API ready at http://localhost:${port}`)
})
<% } else { %>interface CustomerAction {
  customerName: string
  nextAction: string
}

const pendingActions: CustomerAction[] = [
  {
    customerName: '华东渠道续约',
    nextAction: '补齐采购审批附件',
  },
]

for (const action of pendingActions) {
  console.log(`${action.customerName}: ${action.nextAction}`)
}
<% } %>
